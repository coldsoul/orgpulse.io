---
// src/pages/features.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import SeverityBadge from '../components/SeverityBadge.astro';
import type { Severity } from '../components/SeverityBadge.astro';
import { MARKETPLACE_URL } from '../consts';

const patterns: Array<{
  id: string;
  severity: Severity;
  name: string;
  description: string;
  signals: string;
  actions: string;
  borderColor: string;
  bgColor: string;
}> = [
  {
    id: 'P-001', severity: 'WARNING',
    name: 'Chronic WIP Inflation',
    description: 'Work in progress has been rising for 4 or more consecutive sprints while throughput stays flat. Your team is starting more work than it\'s finishing — a classic sign of context-switching and hidden bottlenecks.',
    signals: 'WIP trend · Throughput trend · Absolute WIP vs team size',
    actions: 'Enforce WIP limits · Audit in-progress items · Review intake with stakeholders',
    borderColor: '#FF6B6B', bgColor: '#FFF3F3',
  },
  {
    id: 'P-002', severity: 'WARNING',
    name: 'Stalled Flow',
    description: 'Cycle time has become unpredictable — some items move quickly while others get stuck for days. The variance in how long work takes signals bottlenecks or dependencies that don\'t affect all work equally.',
    signals: 'Cycle time variance · Median cycle time · Sprint-over-sprint trend',
    actions: 'Escalate long-running blockers · Review external dependencies · Revisit work item sizing',
    borderColor: '#FF6B6B', bgColor: '#FFF3F3',
  },
  {
    id: 'P-003', severity: 'WARNING',
    name: 'Overloaded Team',
    description: 'WIP is more than 20% above your team\'s baseline while throughput has dropped more than 15%. Adding more work to an overloaded team slows everything down further.',
    signals: 'WIP vs baseline · Throughput vs baseline · Combined trend over 2+ sprints',
    actions: 'Reduce active WIP · Shield team from mid-sprint additions · Deprioritise lower-value streams',
    borderColor: '#FF6B6B', bgColor: '#FFF3F3',
  },
  {
    id: 'P-004', severity: 'CRITICAL',
    name: 'Quality Crisis Signal',
    description: 'Bug creation rate has risen more than 30% above your team\'s normal rate while throughput has also declined. Quality controls are under strain — pressured delivery is likely reducing time for testing and review.',
    signals: 'Bug creation rate vs baseline · Throughput trend · Combined in single sprint',
    actions: 'Review release process changes · Check quality gates · Address technical debt consciously',
    borderColor: '#DC2626', bgColor: '#FEE2E2',
  },
  {
    id: 'P-005', severity: 'WATCH',
    name: 'Invisible Backlog Pressure',
    description: 'Lead time is rising while cycle time stays stable — meaning items are waiting longer before work starts. The bottleneck is in your backlog queue, not in active delivery.',
    signals: 'Lead time vs baseline · Cycle time stability · Sustained trend over 3+ sprints',
    actions: 'Review and prune backlog · Check intake rate vs capacity · Clarify prioritisation process',
    borderColor: '#D97706', bgColor: '#FFFBEB',
  },
];

const grades = [
  { grade: 'A', range: '85–100', label: 'Healthy', description: 'No active diagnoses or minor Watch signals only', bg: '#D1FAE5', color: '#059669' },
  { grade: 'B', range: '70–84', label: 'Needs Attention', description: 'One or more Warning-level diagnoses active', bg: '#FEF3C7', color: '#D97706' },
  { grade: 'C', range: '55–69', label: 'Under Pressure', description: 'Multiple patterns or one Critical diagnosis', bg: '#FFEDD5', color: '#EA580C' },
  { grade: 'D', range: '40–54', label: 'At Risk', description: 'Sustained pressure; multiple Critical diagnoses', bg: '#FEE2E2', color: '#DC2626' },
  { grade: 'F', range: '0–39',  label: 'Critical', description: 'Severe dysfunction; immediate intervention needed', bg: '#1E293B', color: '#F8FAFC' },
];

const gates = [
  { title: '14-day calibration gate', body: 'No diagnoses in the first two weeks. OrgPulse learns your baseline before comparing against it.' },
  { title: 'Confidence threshold', body: 'Patterns require ≥85% data completeness. Sparse or early-stage data cannot trigger a diagnosis.' },
  { title: 'Multi-sprint confirmation', body: 'Most patterns require evidence across 2–4 consecutive sprints. One-off abnormal sprints are ignored.' },
  { title: 'Personal baseline', body: 'Compared against your own team\'s history, not a universal benchmark. What\'s normal for you is what matters.' },
  { title: 'Team feedback loop', body: 'Mark a diagnosis "Not Accurate" and OrgPulse learns. After repeated signals, it automatically tightens that pattern\'s threshold.' },
];
---

<BaseLayout
  title="Features"
  description="Five diagnostic patterns, a health score, and five layers of false positive defence — everything OrgPulse detects and how."
>

  <!-- ── PAGE HERO ── -->
  <section class="page-hero">
    <div class="container">
      <p class="section-label">Features</p>
      <h1>An organisational <span class="highlight">mechanic</span>,<br />not another metrics dashboard.</h1>
      <p class="subtitle">OrgPulse watches five workflow signals and only fires a diagnosis when a real, sustained dysfunction pattern is confirmed. No noise. No vanity metrics. Just the problems that matter.</p>
    </div>
  </section>

  <!-- ── PATTERNS ── -->
  <section class="section">
    <div class="container">
      <p class="section-label">Diagnostic patterns</p>
      <h2>Five patterns. All the dysfunction that matters.</h2>
      <div class="pattern-list">
        {patterns.map(p => (
          <div class="pattern-card" style={`border-color:${p.borderColor}`}>
            <div class="pattern-bar" style={`background:${p.borderColor}`}></div>
            <div class="pattern-body">
              <div class="pattern-meta">
                <SeverityBadge severity={p.severity} />
                <span class="pattern-id">{p.id}</span>
              </div>
              <h3>{p.name}</h3>
              <p class="pattern-desc">{p.description}</p>
              <div class="pattern-panels">
                <div class="panel" style={`background:${p.bgColor}`}>
                  <span class="panel-label">Signals watched</span>
                  <span class="panel-body">{p.signals}</span>
                </div>
                <div class="panel" style={`background:${p.bgColor}`}>
                  <span class="panel-label">Typical actions</span>
                  <span class="panel-body">{p.actions}</span>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── HEALTH SCORE ── -->
  <section class="section-alt">
    <div class="container">
      <p class="section-label">Health score</p>
      <h2>One number. Full picture.</h2>
      <div class="score-layout">
        <div class="score-grades">
          <p class="score-intro">Every team gets a health score from 0–100 and a letter grade. Each active diagnosis deducts points. The score reflects sustained workflow health — not a single sprint's performance.</p>
          <div class="grade-list">
            {grades.map(g => (
              <div class="grade-row">
                <div class="grade-badge" style={`background:${g.bg};color:${g.color}`}>{g.grade}</div>
                <div>
                  <span class="grade-range">{g.range} · {g.label}</span>
                  <span class="grade-desc">{g.description}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="score-deductions">
          <p class="panel-label" style="margin-bottom:1rem">Score deductions</p>
          <div class="deduction-row"><span>Watch diagnosis</span><span style="color:var(--color-amber-watch);font-weight:700">−5 points</span></div>
          <div class="deduction-row"><span>Warning diagnosis</span><span style="color:var(--color-coral);font-weight:700">−15 points</span></div>
          <div class="deduction-row" style="border-bottom:none"><span>Critical diagnosis</span><span style="color:var(--color-red-critical);font-weight:700">−30 points</span></div>
          <div class="deduction-note">The score reflects systemic health over time. Resolving a diagnosis causes it to recover gradually as the pattern clears.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── FALSE POSITIVE GUARD ── -->
  <section class="section">
    <div class="container">
      <p class="section-label">False positive defence</p>
      <h2>OrgPulse doesn't fire on noise.</h2>
      <p class="subtitle" style="max-width:560px;margin-bottom:2.5rem">Every diagnosis must pass five layers of gates before appearing on your dashboard. A single bad sprint never triggers an alert.</p>
      <div class="gates">
        {gates.map(g => (
          <div class="gate">
            <h3>{g.title}</h3>
            <p>{g.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA ── -->
  <section class="section-cta">
    <div class="container" style="text-align:center">
      <h2 style="margin-bottom:0.75rem">See it working on your team.</h2>
      <p class="subtitle" style="margin-bottom:1.75rem">Available on the Atlassian Marketplace. Works with Jira Software cloud.</p>
      <a href={MARKETPLACE_URL} class="btn-primary" target="_blank" rel="noopener noreferrer">
        Install OrgPulse on Marketplace →
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  .container { max-width: 1280px; margin: 0 auto; padding: 0 2.5rem; }

  .section     { padding: 4rem 0; }
  .section-alt { padding: 4rem 0; background: var(--color-surface); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); }
  .section-cta { padding: 4rem 0; background: var(--color-teal-surface); border-top: 2px solid var(--color-teal-border); text-align: center; }

  .section-label { color: var(--color-muted); font-size: 0.6875rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 0.625rem; }

  h2 { color: var(--color-charcoal); font-size: 1.75rem; font-weight: 800; line-height: 1.25; margin-bottom: 2.5rem; }

  .page-hero { padding: 4.5rem 0 3.5rem; border-bottom: 1px solid var(--color-border); }
  h1 { color: var(--color-charcoal); font-size: clamp(1.875rem, 4vw, 2.5rem); font-weight: 800; line-height: 1.15; margin-bottom: 1rem; }
  .highlight { color: var(--color-teal); }
  .subtitle { color: var(--color-slate); font-size: 1rem; line-height: 1.7; max-width: 580px; }

  /* Patterns */
  .pattern-list { display: flex; flex-direction: column; gap: 0.875rem; }
  .pattern-card { display: flex; border: 1px solid; border-radius: 10px; overflow: hidden; }
  .pattern-bar  { width: 5px; flex-shrink: 0; }
  .pattern-body { padding: 1.5rem 1.75rem; flex: 1; }
  .pattern-meta { display: flex; align-items: center; gap: 0.625rem; margin-bottom: 0.625rem; }
  .pattern-id   { color: var(--color-muted); font-size: 0.6875rem; }
  .pattern-body h3 { color: var(--color-charcoal); font-size: 1.0625rem; font-weight: 800; margin-bottom: 0.375rem; }
  .pattern-desc { color: var(--color-slate); font-size: 0.8125rem; line-height: 1.7; margin-bottom: 0.875rem; }
  .pattern-panels { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }
  .panel { border-radius: 6px; padding: 0.75rem 0.875rem; display: flex; flex-direction: column; gap: 0.25rem; }
  .panel-label { color: var(--color-muted); font-size: 0.625rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; }
  .panel-body  { color: var(--color-charcoal); font-size: 0.75rem; line-height: 1.55; }

  /* Health score */
  .score-layout { display: grid; grid-template-columns: 1fr 340px; gap: 2rem; align-items: start; }
  .score-intro  { color: var(--color-slate); font-size: 0.875rem; line-height: 1.7; margin-bottom: 1.25rem; }
  .grade-list   { display: flex; flex-direction: column; gap: 0.625rem; }
  .grade-row    { display: flex; gap: 0.75rem; align-items: center; }
  .grade-badge  { width: 36px; height: 36px; border-radius: 6px; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 0.875rem; flex-shrink: 0; }
  .grade-range  { display: block; color: var(--color-charcoal); font-size: 0.8125rem; font-weight: 600; }
  .grade-desc   { display: block; color: var(--color-muted); font-size: 0.75rem; }
  .score-deductions { background: #fff; border: 1px solid var(--color-border); border-radius: 10px; padding: 1.5rem; }
  .deduction-row { display: flex; justify-content: space-between; padding: 0.625rem 0; border-bottom: 1px solid var(--color-border); color: var(--color-charcoal); font-size: 0.8125rem; }
  .deduction-note { margin-top: 1rem; background: var(--color-teal-surface); border-radius: 6px; padding: 0.75rem; color: var(--color-charcoal); font-size: 0.75rem; line-height: 1.6; }

  /* Gates */
  .gates { display: grid; grid-template-columns: repeat(5, 1fr); gap: 1.25rem; }
  .gate { border-left: 3px solid var(--color-teal); padding-left: 1rem; }
  .gate h3 { color: var(--color-charcoal); font-size: 0.8125rem; font-weight: 700; margin-bottom: 0.375rem; }
  .gate p  { color: var(--color-slate); font-size: 0.75rem; line-height: 1.6; }

  .btn-primary { display: inline-block; background: var(--color-teal); color: #fff; font-size: 0.9375rem; font-weight: 700; padding: 0.8125rem 1.5rem; border-radius: 6px; transition: opacity 0.15s; }
  .btn-primary:hover { opacity: 0.88; }

  @media (max-width: 1024px) {
    .gates { grid-template-columns: repeat(3, 1fr); }
    .score-layout { grid-template-columns: 1fr; }
  }

  @media (max-width: 768px) {
    .pattern-panels { grid-template-columns: 1fr; }
    .gates { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 480px) {
    .gates { grid-template-columns: 1fr; }
  }
</style>
