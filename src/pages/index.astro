---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import SeverityBadge from '../components/SeverityBadge.astro';
import { MARKETPLACE_URL } from '../consts';
---

<BaseLayout title="Know your team's health before it becomes a crisis">

  <!-- ── HERO ─────────────────────────────────────────── -->
  <section class="hero">
    <div class="container">
      <span class="badge-pill">JIRA CLOUD APP</span>
      <h1>Know your team's <span class="highlight">health</span><br />before it becomes a crisis.</h1>
      <p class="subtitle">
        OrgPulse monitors your Jira workflow and detects dysfunction patterns —
        chronic WIP inflation, stalled flow, overloaded teams — before they compound into real problems.
      </p>
      <div class="hero-cta">
        <a href={MARKETPLACE_URL} class="btn-primary" target="_blank" rel="noopener noreferrer">
          Install on Marketplace →
        </a>
        <span class="cta-note">No setup required · Works in minutes</span>
      </div>

      <div class="stats-row">
        <div class="stat">
          <span class="stat-value">5</span>
          <span class="stat-label">diagnostic patterns</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-value">A–F</span>
          <span class="stat-label">team health grade</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-value">0</span>
          <span class="stat-label">raw issue data stored</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-value">14d</span>
          <span class="stat-label">calibration, then live</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── HOW IT WORKS ──────────────────────────────────── -->
  <section class="section-alt">
    <div class="container">
      <p class="section-label">How it works</p>
      <h2>Three steps from install to insight.</h2>
      <div class="cards-3">
        <div class="card">
          <span class="step-num">01</span>
          <h3>Connect to Jira</h3>
          <p>Install from the Atlassian Marketplace. OrgPulse reads your Jira workflow data — issue changelogs, sprint history, team membership. No configuration needed to start.</p>
        </div>
        <div class="card">
          <span class="step-num">02</span>
          <h3>Learn your baseline</h3>
          <p>For 14 days, OrgPulse learns what's normal for your team — your typical WIP, cycle time, throughput. Diagnoses compare against your team's own history, not industry benchmarks.</p>
        </div>
        <div class="card">
          <span class="step-num">03</span>
          <h3>Surface diagnoses</h3>
          <p>When a real dysfunction pattern emerges — confirmed across multiple sprints — OrgPulse surfaces a plain-English diagnosis with confidence score, evidence, and recommended actions.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── PATTERNS ──────────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <p class="section-label">What we detect</p>
      <div class="patterns-header">
        <h2>Five patterns. All the dysfunction that matters.</h2>
        <a href="/features" class="text-link">See full details →</a>
      </div>
      <div class="patterns-grid">
        <div class="pattern-card">
          <SeverityBadge severity="WARNING" />
          <div>
            <h3>Chronic WIP Inflation</h3>
            <p>WIP rising for 4+ sprints while throughput stays flat. Your team is starting more than it's finishing.</p>
          </div>
        </div>
        <div class="pattern-card">
          <SeverityBadge severity="WARNING" />
          <div>
            <h3>Stalled Flow</h3>
            <p>Cycle time variance spiking. Some work moves fast, other work gets stuck. Hidden bottlenecks.</p>
          </div>
        </div>
        <div class="pattern-card">
          <SeverityBadge severity="WARNING" />
          <div>
            <h3>Overloaded Team</h3>
            <p>High WIP + declining throughput. Classic overcommitment — adding more work slows everything.</p>
          </div>
        </div>
        <div class="pattern-card">
          <SeverityBadge severity="CRITICAL" />
          <div>
            <h3>Quality Crisis Signal</h3>
            <p>Bug rate rising 30%+ while throughput drops. Quality controls are under strain.</p>
          </div>
        </div>
        <div class="pattern-card pattern-card--wide">
          <SeverityBadge severity="WATCH" />
          <div>
            <h3>Invisible Backlog Pressure</h3>
            <p>Lead time rising while cycle time stays stable. Work is queueing before it starts.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── PRIVACY STRIP ─────────────────────────────────── -->
  <section class="section-teal">
    <div class="container">
      <p class="section-label">Privacy by design</p>
      <h2>Your team's data stays private.</h2>
      <div class="trust-row">
        <div class="trust-item">
          <span class="trust-check">✓</span>
          <div>
            <h3>No raw data stored</h3>
            <p>Issue titles, descriptions, and assignee names are never written to storage. Only computed aggregates.</p>
          </div>
        </div>
        <div class="trust-item">
          <span class="trust-check">✓</span>
          <div>
            <h3>No individual metrics</h3>
            <p>OrgPulse aggregates to team level. No per-person performance data exists at any layer.</p>
          </div>
        </div>
        <div class="trust-item">
          <span class="trust-check">✓</span>
          <div>
            <h3>Atlassian Forge platform</h3>
            <p>Runs entirely within Atlassian's infrastructure. Your data never leaves the platform.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── FINAL CTA ─────────────────────────────────────── -->
  <section class="section cta-section">
    <div class="container" style="text-align:center">
      <h2>Ready to check on your team?</h2>
      <p class="subtitle">Available on the Atlassian Marketplace. Works with Jira Software cloud.</p>
      <a href={MARKETPLACE_URL} class="btn-primary" target="_blank" rel="noopener noreferrer">
        Install OrgPulse on Marketplace →
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2.5rem;
  }

  /* ── Sections ── */
  .section    { padding: 4rem 0; }
  .section-alt { padding: 4rem 0; background: var(--color-surface); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); }
  .section-teal { padding: 3.5rem 0; background: var(--color-teal-surface); border-top: 2px solid var(--color-teal-border); border-bottom: 2px solid var(--color-teal-border); }
  .cta-section { border-top: 1px solid var(--color-border); }

  .section-label {
    color: var(--color-muted);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.625rem;
  }

  h2 {
    color: var(--color-charcoal);
    font-size: 1.75rem;
    font-weight: 800;
    line-height: 1.25;
    margin-bottom: 2.5rem;
  }

  /* ── Hero ── */
  .hero { padding: 5rem 0 4rem; }

  .badge-pill {
    display: inline-block;
    background: var(--color-teal-surface);
    color: var(--color-teal);
    font-size: 0.6875rem;
    font-weight: 700;
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    border: 1px solid var(--color-teal-border);
    letter-spacing: 0.04em;
    margin-bottom: 1.25rem;
  }

  h1 {
    color: var(--color-charcoal);
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: 1rem;
    max-width: 680px;
  }

  .highlight { color: var(--color-teal); }

  .subtitle {
    color: var(--color-slate);
    font-size: 1rem;
    line-height: 1.7;
    max-width: 520px;
    margin-bottom: 1.75rem;
  }

  .hero-cta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }

  .btn-primary {
    display: inline-block;
    background: var(--color-teal);
    color: #fff;
    font-size: 0.9375rem;
    font-weight: 700;
    padding: 0.8125rem 1.5rem;
    border-radius: 6px;
    transition: opacity 0.15s;
  }

  .btn-primary:hover { opacity: 0.88; }

  .cta-note {
    color: var(--color-slate);
    font-size: 0.8125rem;
  }

  .stats-row {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    padding-top: 1.75rem;
    border-top: 1px solid var(--color-border);
    align-items: center;
  }

  .stat-value {
    display: block;
    color: var(--color-teal);
    font-size: 1.75rem;
    font-weight: 800;
    line-height: 1;
    margin-bottom: 0.25rem;
  }

  .stat-label {
    color: var(--color-muted);
    font-size: 0.75rem;
  }

  .stat-divider {
    width: 1px;
    height: 36px;
    background: var(--color-border);
    flex-shrink: 0;
  }

  /* ── How it works ── */
  .cards-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .card {
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.5rem;
  }

  .step-num {
    display: block;
    color: var(--color-teal);
    font-size: 1.375rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
  }

  .card h3 {
    color: var(--color-charcoal);
    font-size: 0.9375rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .card p {
    color: var(--color-slate);
    font-size: 0.8125rem;
    line-height: 1.6;
  }

  /* ── Patterns ── */
  .patterns-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 2rem;
  }

  .patterns-header h2 { margin-bottom: 0; max-width: 400px; }

  .text-link {
    color: var(--color-teal);
    font-size: 0.8125rem;
    font-weight: 600;
    border-bottom: 1px solid var(--color-teal);
    padding-bottom: 1px;
    flex-shrink: 0;
  }

  .patterns-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .pattern-card {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.25rem;
    display: flex;
    gap: 0.875rem;
    align-items: flex-start;
  }

  .pattern-card--wide { grid-column: 1 / 2; }

  .pattern-card h3 {
    color: var(--color-charcoal);
    font-size: 0.875rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
  }

  .pattern-card p {
    color: var(--color-slate);
    font-size: 0.75rem;
    line-height: 1.55;
  }

  /* ── Trust ── */
  .trust-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .trust-item {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
  }

  .trust-check {
    color: var(--color-teal);
    font-size: 1rem;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .trust-item h3 {
    color: var(--color-charcoal);
    font-size: 0.9375rem;
    font-weight: 700;
    margin-bottom: 0.375rem;
  }

  .trust-item p {
    color: var(--color-slate);
    font-size: 0.8125rem;
    line-height: 1.6;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .cards-3, .patterns-grid, .trust-row {
      grid-template-columns: 1fr;
    }
    .pattern-card--wide { grid-column: auto; }
    .stat-divider { display: none; }
    .patterns-header { flex-direction: column; align-items: flex-start; gap: 0.5rem; }
  }
</style>
