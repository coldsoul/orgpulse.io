---
// src/components/docs/DocsSidebar.astro
import { getCollection } from 'astro:content';

interface Props {
  currentSlug: string;
}

const { currentSlug } = Astro.props;

const allDocs = await getCollection('docs');

const categories = [
  { key: 'tutorials',    label: 'Tutorials' },
  { key: 'how-to',       label: 'How-to Guides' },
  { key: 'reference',    label: 'Reference' },
  { key: 'explanation',  label: 'Explanation' },
] as const;

const docsByCategory = categories.map(cat => ({
  ...cat,
  docs: allDocs
    .filter(d => d.data.category === cat.key)
    .sort((a, b) => a.data.order - b.data.order)
    .map(d => ({
      title: d.data.title,
      slug: d.id.split('/').pop()!,
    })),
}));
---

<aside class="sidebar">
  <slot name="search" />
  <nav class="sidebar-nav" aria-label="Documentation navigation">
    {docsByCategory.map(cat => (
      <div class="sidebar-section">
        <p class="sidebar-category">{cat.label}</p>
        <ul>
          {cat.docs.map(doc => (
            <li>
              <a
                href={`/docs/${doc.slug}`}
                class:list={['sidebar-link', { active: doc.slug === currentSlug }]}
              >
                {doc.title}
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </nav>
</aside>

<style>
  .sidebar {
    width: 220px;
    flex-shrink: 0;
    border-right: 1px solid var(--color-border);
    padding: 1.5rem 0;
    background: var(--color-surface);
    min-height: calc(100vh - 60px);
  }

  .sidebar-nav { padding: 0; }

  .sidebar-section { padding: 0 1.25rem; margin-bottom: 0.25rem; }
  .sidebar-section + .sidebar-section { margin-top: 1.25rem; }

  .sidebar-category {
    color: var(--color-muted);
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  ul { list-style: none; display: flex; flex-direction: column; gap: 2px; }

  .sidebar-link {
    display: block;
    color: var(--color-slate);
    font-size: 0.8125rem;
    padding: 0.375rem 0.625rem;
    border-radius: 4px;
    border-left: 3px solid transparent;
    transition: color 0.1s, background 0.1s;
    line-height: 1.4;
  }

  .sidebar-link:hover {
    color: var(--color-charcoal);
    background: #eff1f5;
  }

  .sidebar-link.active {
    color: var(--color-teal);
    background: var(--color-teal-surface);
    border-left-color: var(--color-teal);
    font-weight: 600;
  }
</style>
