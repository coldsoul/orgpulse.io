---
// src/components/Footer.astro
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-left">
      <img src="/logo/orgpulse-icon.svg" alt="OrgPulse" width="20" height="20" />
      <span class="footer-copy">© {year} OrgPulse</span>
    </div>
    <nav class="footer-links" aria-label="Footer navigation">
      <a href="/privacy">Privacy Policy</a>
      <a href="/terms">Terms of Service</a>
      <a href="/dpa">Data Processing Addendum</a>
      <a href="/contact">Contact</a>
    </nav>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    padding: 1.25rem 0;
    margin-top: auto;
  }

  .footer-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .footer-left {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .footer-copy {
    color: var(--color-muted);
    font-size: 0.75rem;
  }

  .footer-links {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .footer-links a {
    color: var(--color-muted);
    font-size: 0.75rem;
    transition: color 0.15s;
  }

  .footer-links a:hover {
    color: var(--color-teal);
  }
</style>
