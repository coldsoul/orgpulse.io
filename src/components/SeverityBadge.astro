---
// src/components/SeverityBadge.astro
export type Severity = 'WARNING' | 'CRITICAL' | 'WATCH';

interface Props {
  severity: Severity;
}

const { severity } = Astro.props;

const styles: Record<Severity, { bg: string; color: string }> = {
  WARNING:  { bg: '#FFF3F3', color: '#FF6B6B' },
  CRITICAL: { bg: '#FEE2E2', color: '#DC2626' },
  WATCH:    { bg: '#FFFBEB', color: '#D97706' },
};

const { bg, color } = styles[severity];
---

<span class="badge" style={`background:${bg};color:${color}`}>{severity}</span>

<style>
  .badge {
    font-size: 0.625rem;
    font-weight: 700;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    white-space: nowrap;
    letter-spacing: 0.04em;
    flex-shrink: 0;
  }
</style>
